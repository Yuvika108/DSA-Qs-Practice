class Solution {
public:
    int climbStairs(int n) {
        if(n<=2) return n;
        
        int f_1=1;
        int f_2=2;

        for(int i=3; i<=n; i++){
            int curr = f_1 + f_2;
            f_1 = f_2;
            f_2 = curr;
        }

        return f_2;

        //return climbStairs(n-1)+climbStairs(n-2);
    }
};
