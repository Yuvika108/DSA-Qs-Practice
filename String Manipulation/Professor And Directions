#include <bits/stdc++.h>
#define ll long long
using namespace std;

int main() {
	int t;
	cin >> t;
	
	while(t--){
	    ll n;
	    cin >> n;
	    
	    string s;
	    cin >> s;
	    
	    bool ans = false;
	    
	    for(int i=0; i<n-1; i++){
	        if(s[i]==s[i+1]) ans = true;
	    }
	    
	    if(ans) cout << "YES\n";
	    else cout << "NO\n";
	    
	}
	
    return 0;
}
