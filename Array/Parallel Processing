#include <bits/stdc++.h>
#define ll long long
using namespace std;

int main() {
	int t;
	cin >> t;
	
	while(t--){
	    ll n;
	    cin >> n;
	    
	    vector<ll> A(n);
	    for(ll i=0; i<n; i++) cin >> A[i];
	    
	    ll sum = 0;
	    for(ll i=0; i<n; i++) sum+=A[i];
	    
	    ll prefix = 0;
	    ll ans = LLONG_MAX;
	    
	    
    	for(ll i=0; i<=n; i++){
    	    ll suffix = sum-prefix;
    	    ans = min(ans, max(prefix, suffix));
    	    if(i<n) prefix+=A[i];
    	}
	    
	    cout << ans << "\n";
	    
	}
	
    return 0;
}
