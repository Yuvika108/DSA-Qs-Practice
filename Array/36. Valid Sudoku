class Solution {
public:
    bool isValidSudoku(vector<vector<char>>& board) {
        // rowUsed[9][9] tracks if digit (num-1) is used in row i
        bool rowUsed[9][9] = {false};
        bool colUsed[9][9] = {false};
        bool boxUsed[9][9] = {false};

        for (int r = 0; r < 9; ++r) {
            for (int c = 0; c < 9; ++c) {
                if (board[r][c] == '.') continue;

                int num = board[r][c] - '1'; // Convert '1'-'9' to index 0-8
                int boxIndex = (r / 3) * 3 + (c / 3);

                // Check if the number already exists in the current row, column, or box
                if (rowUsed[r][num] || colUsed[c][num] || boxUsed[boxIndex][num]) {
                    return false;
                }

                // Mark the number as seen
                rowUsed[r][num] = true;
                colUsed[c][num] = true;
                boxUsed[boxIndex][num] = true;
            }
        }

        return true;
    }
};
