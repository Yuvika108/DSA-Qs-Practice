#include <bits/stdc++.h>
#define ll long long
using namespace std;

int main() {
    int t;
    scanf("%d", &t);
    
    while(t--){
        ll n;
        scanf("%lld", &n);
        
        vector<ll> g(n);
        for(ll i=0; i<n; i++) scanf("%lld", &g[i]);
        
        ll max_diff = 0;
        ll min_val = g[0];
        for(ll i=1; i<n; i++){
            max_diff = max(max_diff, g[i]-min_val);
            min_val = min(min_val, g[i]);
        }
        
        if(max_diff>0) printf("%lld\n", max_diff);
        else printf("UNFIT\n");
    }
    
    return 0;
}
