#include <bits/stdc++.h>
#define ll long long
using namespace std;

int main() {
	ll t;
	cin >> t;
	
	while(t--){
	    ll n, m;
	    cin >> n >> m;
	    
	    vector<ll> A(n);
	    for(ll i=0; i<n; i++) cin >> A[i];
	    
	    vector<ll> B(n);
	    for(ll i=0; i<n; i++) cin >> B[i];
	    
	    unordered_map<ll, ll> freq;
	    for(int i=0; i<n; i++) freq[A[i]%m]++;
	    
	    ll ans = 0;
	    
	    for(int j=0; j<n; j++){
	        ll need = (m-B[j]%m)%m;
	        if(freq.count(need)) ans+=freq[need];
	    }
	    
	    cout << ans << "\n";
	    
	}
	
    return 0;
}
