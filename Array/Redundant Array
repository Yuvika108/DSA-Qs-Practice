#include <bits/stdc++.h>
#define ll long long
using namespace std;

int main() {
	ll t;
	cin >> t;
	
	while(t--){
	    ll n;
	    cin >> n;
	    
	    ll A[n];
	    
	    map<int, int> mp;
	    
	    for(int i=0; i<n; i++){
	        cin >> A[i];
	        mp[A[i]]++;
	    }
	    
	    ll int min_val = INT_MAX;
	    
	    for(auto it: mp){
	        min_val = min(min_val, (ll) (n-it.second)*it.first);
	    }
	    
	    cout << min(min_val, (ll) n) << endl;
	}
	
    return 0;
}
