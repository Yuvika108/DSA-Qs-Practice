#include <bits/stdc++.h>
#define ll long long
using namespace std;

int main() {
	int t;
	cin >> t;
	
	while(t--){
	    int n;
	    cin >> n;
	    
	    int a[n][n];
	    int flag = 0;
	    int cnt_1 = 0, cnt_2 = 0;
	    
	    for(int i=0; i<n; i++){
	        for(int j=0; j<n; j++){
	            cin >> a[i][j];
	        }
	    }
	    
	    for(int i=0; i<n; i++){
	        flag = 0;
	        for(int j=0; j<n; j++){
	            if(a[i][j] == 0) flag = 1;
	        }
	        if(flag){
	            cnt_1++;
	        }
	    }
	    
	    
	    for(int i=0; i<n; i++){
	        flag = 0;
	        for(int j=0; j<n; j++){
	            if(a[j][i] == 0) flag = 1;
	        }
	        if(flag){
	            cnt_2++;
	        }
	    }
	    
	    if(cnt_1==n && cnt_2==n) cout << "YES\n";
	    else cout << "NO\n";
	    
	}
	
    return 0;
}

